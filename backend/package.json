{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "postinstall": "bunx lefthook install",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:unit": "find src -name '*.test.ts' ! -name '*.int.test.ts' | xargs bun test",
    "test:int": "find src -name '*.int.test.ts' ! -name '*.repository.int.test.ts' | xargs bun test",
    "test:repo": "find src -name '*.repository.int.test.ts' | xargs bun test",
    "dev": "bun run --watch src/index.ts",
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
    "db:seed": "bun --env-file .env --bun drizzle-kit seed"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.6",
    "@elysiajs/openapi": "^1.4.13",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.21",
    "elysia-rate-limit": "^4.5.0",
    "pg": "^8.16.3",
    "pino": "^10.3.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/pg": "^8.16.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8",
    "drizzle-seed": "^0.3.1",
    "lefthook": "^2.0.13",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  }
}
